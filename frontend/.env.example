# Backend API base URL (required)
# Production:
NEXT_PUBLIC_API_BASE_URL=https://api.gjxpress.net
# Local development:
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Site URL (for SEO/metadata)
NEXT_PUBLIC_SITE_URL=https://gjxpress.net

# Optional public app version shown in Public footer and Admin Portal.
# Example: 2026.05.07
# Production can also show the short Vercel commit SHA when
# NEXT_PUBLIC_VERCEL_GIT_COMMIT_SHA is exposed by the hosting platform.
NEXT_PUBLIC_APP_VERSION=

# API debug logging (default: true in development, false in production)
NEXT_PUBLIC_API_DEBUG=true
