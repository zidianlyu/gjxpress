# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/gjxpress?schema=public"

# JWT
JWT_SECRET="change_this_to_a_long_random_secret"
JWT_EXPIRES_IN="7d"

# WeChat Mini Program
WX_APPID="wx_your_appid"
WX_SECRET="your_wechat_app_secret"
WX_CODE2SESSION_URL="https://api.weixin.qq.com/sns/jscode2session"

# COS (Tencent Cloud Object Storage – for images)
COS_SECRET_ID="your_cos_secret_id"
COS_SECRET_KEY="your_cos_secret_key"
COS_BUCKET="your-bucket-name"
COS_REGION="ap-guangzhou"
COS_BASE_URL="https://your-bucket-name.cos.ap-guangzhou.myqcloud.com"

# App
PORT=3000
NODE_ENV=development
