generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum OrderStatus {
  UNINBOUND
  INBOUNDED
  USER_CONFIRM_PENDING
  REVIEW_PENDING
  PAYMENT_PENDING
  PAID
  READY_TO_SHIP
  SHIPPED
  COMPLETED
  EXCEPTION
  CANCELLED
}

enum PackageStatus {
  CREATED
  INBOUNDED
  USER_CONFIRM_PENDING
  CONFIRMED
  EXCEPTION
  CONSOLIDATED
  SHIPPED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PROCESSING
  PENDING
  PAID
  REFUNDED
  WAIVED
}

enum AdminRole {
  OWNER
  ADMIN
  WAREHOUSE_STAFF
  US_STAFF
  VIEWER
}

enum AdminStatus {
  ACTIVE
  DISABLED
}

enum InboundPackageStatus {
  UNIDENTIFIED
  ARRIVED
  CONSOLIDATED
}

enum CustomerShipmentStatus {
  PACKED
  SHIPPED
  ARRIVED
  READY_FOR_PICKUP
  PICKED_UP
  EXCEPTION
}

enum MasterShipmentStatus {
  IN_TRANSIT
  SIGNED
  READY_FOR_PICKUP
  EXCEPTION
}

enum SourcePlatform {
  TAOBAO
  JD
  PINDUODUO
  OTHER
}

enum ImageType {
  OUTER
  LABEL
  INNER
  EXCEPTION
  PAYMENT_PROOF
  OTHER
}

enum ImageStatus {
  CREATED
  UPLOADED
  DELETED
}

enum ExceptionType {
  MISSING_ITEM
  WRONG_ITEM
  DAMAGED
  RESTRICTED
  OTHER
}

enum ExceptionStatus {
  OPEN
  PROCESSING
  RESOLVED
  CANCELLED
}

enum ShipmentProvider {
  UPS
  DHL
  EMS
  USPS
  FEDEX
  SEA
  AIR
  OTHER
}

enum ShipmentStatus {
  CREATED
  READY
  SHIPPED
  IN_TRANSIT
  DELIVERED
  EXCEPTION
  CANCELLED
}

enum QrPurpose {
  RECEIPT_CONFIRMATION
  PICKUP_CONFIRMATION
}

enum AdminActionTargetType {
  ORDER
  PACKAGE
  PAYMENT
  SHIPMENT
  EXCEPTION
  IMAGE
  USER
  ADMIN
  SYSTEM
}

enum RecommendationStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  nickname  String?
  avatarUrl String?  @map("avatar_url")
  userCode  String   @unique @map("user_code")
  role      UserRole @default(USER)
  isActive  Boolean  @default(true) @map("is_active")

  orders        Order[]
  qrScanLogs    QrScanLog[]
  notifications Notification[]
  addressUsages AddressUsage[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userCode])
  @@index([createdAt])
  @@map("users")
}

model Admin {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String   @map("password_hash")
  displayName  String?  @map("display_name")
  role         UserRole @default(ADMIN)
  isActive     Boolean  @default(true) @map("is_active")

  inboundRecords InboundRecord[]
  actionLogs     AdminActionLog[]
  shipments      Shipment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([role])
  @@index([isActive])
  @@map("admins")
}

model Order {
  id      String @id @default(cuid())
  orderNo String @unique @map("order_no")
  userId  String @map("user_id")
  user    User   @relation(fields: [userId], references: [id])

  status        OrderStatus   @default(UNINBOUND)
  paymentStatus PaymentStatus @default(UNPAID) @map("payment_status")

  totalActualWeight Decimal? @map("total_actual_weight") @db.Decimal(10, 2)
  totalVolumeWeight Decimal? @map("total_volume_weight") @db.Decimal(10, 2)
  chargeableWeight  Decimal? @map("chargeable_weight") @db.Decimal(10, 2)
  estimatedPrice    Decimal? @map("estimated_price") @db.Decimal(10, 2)
  finalPrice        Decimal? @map("final_price") @db.Decimal(10, 2)
  currency          String   @default("USD")

  manualOverride Boolean @default(false) @map("manual_override")
  adminRemark    String? @map("admin_remark")
  userRemark     String? @map("user_remark")

  packages       Package[]
  paymentRecords PaymentRecord[]
  shipment       Shipment?
  qrCodes        QrCode[]
  exceptions     ExceptionCase[]
  statusLogs     OrderStatusLog[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([orderNo])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@map("orders")
}

model Package {
  id        String @id @default(cuid())
  packageNo String @unique @map("package_no")
  orderId   String @map("order_id")
  order     Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  domesticTrackingNo String?        @map("domestic_tracking_no")
  sourcePlatform     SourcePlatform @default(OTHER) @map("source_platform")
  status             PackageStatus  @default(CREATED)

  actualWeight Decimal? @map("actual_weight") @db.Decimal(10, 2)
  lengthCm     Decimal? @map("length_cm") @db.Decimal(10, 2)
  widthCm      Decimal? @map("width_cm") @db.Decimal(10, 2)
  heightCm     Decimal? @map("height_cm") @db.Decimal(10, 2)
  volumeWeight Decimal? @map("volume_weight") @db.Decimal(10, 2)

  inboundAt       DateTime? @map("inbound_at")
  userConfirmedAt DateTime? @map("user_confirmed_at")
  remark          String?

  goodsItems     GoodsItem[]
  images         PackageImage[]
  inboundRecords InboundRecord[]
  exceptions     ExceptionCase[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([orderId])
  @@index([packageNo])
  @@index([domesticTrackingNo])
  @@index([status])
  @@index([inboundAt])
  @@map("packages")
}

model GoodsItem {
  id        String  @id @default(cuid())
  packageId String  @map("package_id")
  package   Package @relation(fields: [packageId], references: [id], onDelete: Cascade)

  name                  String?
  category              String?
  quantity              Int     @default(1)
  containsSensitiveItem Boolean @default(false) @map("contains_sensitive_item")
  remark                String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([packageId])
  @@index([category])
  @@map("goods_items")
}

model PackageImage {
  id        String   @id @default(cuid())
  packageId String?  @map("package_id")
  package   Package? @relation(fields: [packageId], references: [id], onDelete: SetNull)

  imageType ImageType   @map("image_type")
  status    ImageStatus @default(CREATED)

  bucket      String
  storagePath String  @map("storage_path")
  publicUrl   String? @map("public_url")
  mimeType    String? @map("mime_type")
  sizeBytes   Int?    @map("size_bytes")
  checksum    String?

  uploadedByUserId  String? @map("uploaded_by_user_id")
  uploadedByAdminId String? @map("uploaded_by_admin_id")

  createdAt  DateTime  @default(now()) @map("created_at")
  uploadedAt DateTime? @map("uploaded_at")
  deletedAt  DateTime? @map("deleted_at")

  @@index([packageId])
  @@index([imageType])
  @@index([status])
  @@index([storagePath])
  @@map("package_images")
}

model InboundRecord {
  id        String  @id @default(cuid())
  packageId String  @map("package_id")
  package   Package @relation(fields: [packageId], references: [id], onDelete: Cascade)

  operatorAdminId String @map("operator_admin_id")
  operatorAdmin   Admin  @relation(fields: [operatorAdminId], references: [id])

  checkResult String?  @map("check_result")
  remark      String?
  inboundTime DateTime @default(now()) @map("inbound_time")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([packageId])
  @@index([operatorAdminId])
  @@index([inboundTime])
  @@map("inbound_records")
}

model PaymentRecord {
  id      String @id @default(cuid())
  orderId String @map("order_id")
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  paymentStatus      PaymentStatus @map("payment_status")
  paymentMethod      String?       @map("payment_method")
  amount             Decimal?      @db.Decimal(10, 2)
  currency           String        @default("USD")
  proofImageId       String?       @map("proof_image_id")
  remark             String?
  confirmedByAdminId String?       @map("confirmed_by_admin_id")
  confirmedAt        DateTime?     @map("confirmed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([orderId])
  @@index([paymentStatus])
  @@index([confirmedAt])
  @@map("payment_records")
}

model Shipment {
  id      String @id @default(cuid())
  orderId String @unique @map("order_id")
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  provider           ShipmentProvider
  trackingNumber     String?          @map("tracking_number")
  status             ShipmentStatus   @default(CREATED)
  shippedAt          DateTime?        @map("shipped_at")
  estimatedArrivalAt DateTime?        @map("estimated_arrival_at")
  rawPayload         Json?            @map("raw_payload")
  createdByAdminId   String?          @map("created_by_admin_id")
  createdByAdmin     Admin?           @relation(fields: [createdByAdminId], references: [id])

  events LogisticsTrackingEvent[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([provider])
  @@index([trackingNumber])
  @@index([status])
  @@index([shippedAt])
  @@map("shipments")
}

model LogisticsTrackingEvent {
  id         String   @id @default(cuid())
  shipmentId String   @map("shipment_id")
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  eventStatus   String?   @map("event_status")
  eventLocation String?   @map("event_location")
  description   String?
  eventTime     DateTime? @map("event_time")
  rawPayload    Json?     @map("raw_payload")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([shipmentId])
  @@index([eventTime])
  @@map("logistics_tracking_events")
}

model QrCode {
  id      String @id @default(cuid())
  orderId String @map("order_id")
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  tokenHash String    @map("token_hash")
  purpose   QrPurpose
  expiresAt DateTime  @map("expires_at")
  isUsed    Boolean   @default(false) @map("is_used")
  usedAt    DateTime? @map("used_at")

  scanLogs QrScanLog[]

  createdAt DateTime @default(now()) @map("created_at")

  @@index([orderId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@map("qr_codes")
}

model QrScanLog {
  id       String @id @default(cuid())
  qrCodeId String @map("qr_code_id")
  qrCode   QrCode @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)

  scanUserId   String? @map("scan_user_id")
  scanUser     User?   @relation(fields: [scanUserId], references: [id])
  isAuthorized Boolean @map("is_authorized")
  result       String?
  ipAddress    String? @map("ip_address")
  userAgent    String? @map("user_agent")

  scannedAt DateTime @default(now()) @map("scanned_at")

  @@index([qrCodeId])
  @@index([scanUserId])
  @@index([scannedAt])
  @@map("qr_scan_logs")
}

model ExceptionCase {
  id      String @id @default(cuid())
  orderId String @map("order_id")
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  packageId String?  @map("package_id")
  package   Package? @relation(fields: [packageId], references: [id], onDelete: SetNull)

  type        ExceptionType
  status      ExceptionStatus @default(OPEN)
  description String?
  resolution  String?

  createdByUserId  String?   @map("created_by_user_id")
  createdByAdminId String?   @map("created_by_admin_id")
  resolvedAt       DateTime? @map("resolved_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([orderId])
  @@index([packageId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@map("exception_cases")
}

model AdminActionLog {
  id      String @id @default(cuid())
  adminId String @map("admin_id")
  admin   Admin  @relation(fields: [adminId], references: [id])

  targetType  AdminActionTargetType @map("target_type")
  targetId    String                @map("target_id")
  action      String
  beforeState Json?                 @map("before_state")
  afterState  Json?                 @map("after_state")
  reason      String?
  ipAddress   String?               @map("ip_address")
  userAgent   String?               @map("user_agent")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([adminId])
  @@index([targetType, targetId])
  @@index([action])
  @@index([createdAt])
  @@map("admin_action_logs")
}

model OrderStatusLog {
  id      String @id @default(cuid())
  orderId String @map("order_id")
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  fromStatus    OrderStatus? @map("from_status")
  toStatus      OrderStatus  @map("to_status")
  changedByType String       @map("changed_by_type")
  changedById   String?      @map("changed_by_id")
  reason        String?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([orderId])
  @@index([toStatus])
  @@index([createdAt])
  @@map("order_status_logs")
}

model AddressUsage {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  warehouseAddressId String?  @map("warehouse_address_id")
  copiedAt           DateTime @default(now()) @map("copied_at")

  @@index([userId])
  @@index([copiedAt])
  @@map("address_usages")
}

model WarehouseAddress {
  id           String  @id @default(cuid())
  name         String
  receiverName String  @map("receiver_name")
  phone        String
  country      String  @default("中国")
  province     String
  city         String
  district     String?
  addressLine  String  @map("address_line")
  postalCode   String? @map("postal_code")
  isActive     Boolean @default(true) @map("is_active")
  remark       String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isActive])
  @@map("warehouse_addresses")
}

model Notification {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    String
  title   String?
  body    String?
  payload Json?
  isRead  Boolean   @default(false) @map("is_read")
  sentAt  DateTime? @map("sent_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([type])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

model Recommendation {
  id       String   @id @default(cuid())
  slug     String   @unique
  title    String
  summary  String?
  body     String?
  category String?
  city     String?
  tags     String[] @default([])

  status         RecommendationStatus @default(DRAFT)
  seoTitle       String?              @map("seo_title")
  seoDescription String?              @map("seo_description")

  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([slug])
  @@index([status])
  @@index([category])
  @@index([city])
  @@index([publishedAt])
  @@map("recommendations")
}

// ─── Web Logistics Phase 1 Models ─────────────────────────────────────────────

model AdminAccount {
  id               String      @id @default(uuid()) @db.Uuid
  phoneCountryCode String      @default("+86") @map("phone_country_code") @db.VarChar(8)
  phoneNumber      String      @map("phone_number") @db.VarChar(32)
  passwordHash     String      @map("password_hash")
  role             AdminRole   @default(ADMIN)
  status           AdminStatus @default(ACTIVE)
  displayName      String?     @map("display_name") @db.VarChar(64)
  lastLoginAt      DateTime?   @map("last_login_at")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  @@unique([phoneCountryCode, phoneNumber], map: "admin_accounts_phone_unique")
  @@index([role])
  @@index([status])
  @@map("admin_accounts")
}

model Customer {
  id                    String   @id @default(uuid()) @db.Uuid
  customerCode          String   @unique @map("customer_code") @db.VarChar(16)
  phoneCountryCode      String   @default("+86") @map("phone_country_code") @db.VarChar(8)
  phoneNumber           String   @map("phone_number") @db.VarChar(32)
  wechatId              String?  @map("wechat_id") @db.VarChar(64)
  domesticReturnAddress String?  @map("domestic_return_address") @db.Text
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  inboundPackages   InboundPackage[]
  customerShipments CustomerShipment[]
  transactions      TransactionRecord[]
  registrations     CustomerRegistration[]

  @@unique([phoneCountryCode, phoneNumber], map: "customers_phone_unique")
  @@index([customerCode])
  @@index([phoneNumber])
  @@index([wechatId])
  @@map("customers")
}

model CustomerRegistration {
  id           String @id @default(uuid()) @db.Uuid
  customerCode String @unique @map("customer_code") @db.VarChar(16)

  phoneCountryCode      String  @default("+86") @map("phone_country_code") @db.VarChar(8)
  phoneNumber           String  @map("phone_number") @db.VarChar(32)
  wechatId              String? @map("wechat_id") @db.VarChar(64)
  domesticReturnAddress String? @map("domestic_return_address") @db.Text

  approvedAt        DateTime? @map("approved_at")
  approvedByAdminId String?   @map("approved_by_admin_id") @db.Uuid
  rejectedAt        DateTime? @map("rejected_at")
  rejectedByAdminId String?   @map("rejected_by_admin_id") @db.Uuid
  reviewNote        String?   @map("review_note")

  createdCustomerId String?   @map("created_customer_id") @db.Uuid
  createdCustomer   Customer? @relation(fields: [createdCustomerId], references: [id])

  ipHash    String? @map("ip_hash") @db.VarChar(128)
  userAgent String? @map("user_agent") @db.VarChar(512)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([customerCode])
  @@index([phoneNumber])
  @@index([wechatId])
  @@index([createdAt])
  @@map("customer_registrations")
}

model InboundPackage {
  id                 String               @id @default(uuid()) @db.Uuid
  domesticTrackingNo String?              @unique @map("domestic_tracking_no") @db.VarChar(64)
  customerId         String?              @map("customer_id") @db.Uuid
  customer           Customer?            @relation(fields: [customerId], references: [id])
  status             InboundPackageStatus @default(UNIDENTIFIED)

  warehouseReceivedAt DateTime? @map("warehouse_received_at")
  imageUrls           String[]  @default([]) @map("image_urls")
  note                String?   @map("note")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  shipmentItems CustomerShipmentItem[]

  @@index([customerId])
  @@index([status])
  @@index([domesticTrackingNo])
  @@map("inbound_packages")
}

model CustomerShipment {
  id         String @id @default(uuid()) @db.Uuid
  shipmentNo String @unique @map("shipment_no") @db.VarChar(32)

  customerId String   @map("customer_id") @db.Uuid
  customer   Customer @relation(fields: [customerId], references: [id])

  masterShipmentId String?         @map("master_shipment_id") @db.Uuid
  masterShipment   MasterShipment? @relation(fields: [masterShipmentId], references: [id])

  status        CustomerShipmentStatus @default(PACKED)
  paymentStatus PaymentStatus          @default(UNPAID) @map("payment_status")
  shipmentType  String                 @default("AIR_GENERAL") @map("shipment_type")
  quantity      Int                    @default(1) @map("quantity")

  internationalTrackingNo String? @map("international_tracking_no") @db.VarChar(128)
  publicTrackingEnabled   Boolean @default(true) @map("public_tracking_enabled")

  sentToOverseasAt         DateTime? @map("sent_to_overseas_at")
  arrivedOverseasAt        DateTime? @map("arrived_overseas_at")
  localDeliveryRequestedAt DateTime? @map("local_delivery_requested_at")
  pickedUpAt               DateTime? @map("picked_up_at")
  completedAt              DateTime? @map("completed_at")

  actualWeightKg      Decimal? @map("actual_weight_kg") @db.Decimal(10, 3)
  volumeFormula       String?  @map("volume_formula") @db.VarChar(128)
  billingRateCnyPerKg Decimal? @map("billing_rate_cny_per_kg") @db.Decimal(10, 2)
  billingWeightKg     Decimal? @map("billing_weight_kg") @db.Decimal(10, 3)
  imageUrls           String[] @default([]) @map("image_urls")

  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items        CustomerShipmentItem[]
  transactions TransactionRecord[]

  @@index([customerId])
  @@index([masterShipmentId])
  @@index([status])
  @@index([paymentStatus])
  @@map("customer_shipments")
}

model CustomerShipmentItem {
  id                 String @id @default(uuid()) @db.Uuid
  customerShipmentId String @map("customer_shipment_id") @db.Uuid
  inboundPackageId   String @map("inbound_package_id") @db.Uuid

  customerShipment CustomerShipment @relation(fields: [customerShipmentId], references: [id])
  inboundPackage   InboundPackage   @relation(fields: [inboundPackageId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([inboundPackageId])
  @@unique([customerShipmentId, inboundPackageId])
  @@index([customerShipmentId])
  @@map("customer_shipment_items")
}

model MasterShipment {
  id      String @id @default(uuid()) @db.Uuid
  batchNo String @unique @map("batch_no") @db.VarChar(32)

  vendorName       String @map("vendor_name") @db.VarChar(64)
  vendorTrackingNo String @map("vendor_tracking_no") @db.VarChar(128)
  shipmentType     String @default("AIR_GENERAL") @map("shipment_type")

  status MasterShipmentStatus @default(IN_TRANSIT)

  publicPublished Boolean   @default(true) @map("public_visible")
  publishedAt     DateTime? @map("published_at")

  handedToVendorAt  DateTime? @map("handed_to_vendor_at")
  arrivedOverseasAt DateTime? @map("arrived_overseas_at")
  closedAt          DateTime? @map("closed_at")
  note              String?   @map("admin_note")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  customerShipments CustomerShipment[]

  @@index([status])
  @@index([publicPublished])
  @@index([batchNo])
  @@map("master_shipments")
}

model TransactionRecord {
  id String @id @default(uuid()) @db.Uuid

  customerId String   @map("customer_id") @db.Uuid
  customer   Customer @relation(fields: [customerId], references: [id])

  customerShipmentId String           @map("customer_shipment_id") @db.Uuid
  customerShipment   CustomerShipment @relation(fields: [customerShipmentId], references: [id])

  amountCents Int @map("amount_cents")

  adminNote  String?  @map("admin_note")
  occurredAt DateTime @default(now()) @map("occurred_at")

  createdAt DateTime @default(now()) @map("created_at")
