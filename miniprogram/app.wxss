/* 全局样式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #1f1f1f;
  background-color: #f6f7f9;
  line-height: 1.6;
}

/* 通用容器 */
.container {
  padding: 32rpx;
}

.page-container {
  min-height: 100vh;
  background-color: #f6f7f9;
  padding-bottom: 48rpx;
}

/* 卡片样式 */
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f1f1f;
  margin-bottom: 24rpx;
}

.card-subtitle {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

/* 按钮样式 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 48rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
}

.btn-primary {
  background: #d6a84f;
  color: #fff;
}

.btn-primary:active {
  background: #c49a47;
}

.btn-default {
  background: #fff;
  color: #1f1f1f;
  border: 2rpx solid #eeeeee;
}

.btn-success {
  background: #18a058;
  color: #fff;
}

.btn-success:active {
  background: #158a4a;
}

.btn-danger {
  background: #d03050;
  color: #fff;
}

.btn-danger:active {
  background: #b82844;
}

.btn-warning {
  background: #d6a84f;
  color: #fff;
}

.btn-sm {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
}

.btn-block {
  width: 100%;
}

/* 状态标签 - 在 components/status-tag 中定义 */

/* 列表项 */
.list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.list-item:last-child {
  border-bottom: none;
}

.list-item-label {
  color: #666666;
  font-size: 28rpx;
}

.list-item-value {
  color: #1f1f1f;
  font-size: 28rpx;
  font-weight: 500;
}

/* 空状态 - 在 components/empty-state 中定义 */

/* 错误状态 - 在 components/error-state 中定义 */

/* 快捷入口网格 */
.grid-menu {
  display: flex;
  flex-wrap: wrap;
  padding: 16rpx 0;
}

.grid-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
}

.grid-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  font-size: 48rpx;
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.grid-text {
  font-size: 24rpx;
  color: #666666;
}

/* 地址卡片 */
.address-card {
  background: #f6ffed;
  border: 2rpx solid #b7eb8f;
  border-radius: 16rpx;
  padding: 28rpx;
  position: relative;
}

.address-card .copy-btn {
  position: absolute;
  right: 24rpx;
  top: 24rpx;
  padding: 8rpx 24rpx;
  background: #18a058;
  color: #fff;
  border-radius: 8rpx;
  font-size: 24rpx;
}

/* 加载状态 */
.loading {
  display: flex;
  justify-content: center;
  padding: 48rpx;
}

/* 底部安全区域 */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 品牌区域 */
.brand-section {
  background: linear-gradient(135deg, #d6a84f 0%, #c49a47 100%);
  padding: 48rpx 32rpx;
  color: #fff;
}

.brand-name {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.brand-slogan {
  font-size: 28rpx;
  opacity: 0.9;
}

/* 统计数字 */
.stat-grid {
  display: flex;
  justify-content: space-around;
  padding: 32rpx 0;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 600;
  color: #d6a84f;
}

.stat-label {
  font-size: 24rpx;
  color: #666666;
  margin-top: 8rpx;
}

/* 分割线 */
.divider {
  height: 2rpx;
  background: #eeeeee;
  margin: 24rpx 0;
}

/* 文本样式 */
.text-primary {
  color: #d6a84f;
}

.text-success {
  color: #18a058;
}

.text-danger {
  color: #d03050;
}

.text-warning {
  color: #d6a84f;
}

.text-secondary {
  color: #666666;
}

.text-muted {
  color: #999999;
}

/* 字体大小 */
.text-xs {
  font-size: 24rpx;
}

.text-sm {
  font-size: 26rpx;
}

.text-base {
  font-size: 28rpx;
}

.text-lg {
  font-size: 32rpx;
}

.text-xl {
  font-size: 36rpx;
}

.font-bold {
  font-weight: 600;
}

/* 边距 */
.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-32 { margin-top: 32rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-24 { margin-bottom: 24rpx; }
.mb-32 { margin-bottom: 32rpx; }
.mx-16 { margin-left: 16rpx; margin-right: 16rpx; }
.mx-24 { margin-left: 24rpx; margin-right: 24rpx; }
.p-16 { padding: 16rpx; }
.p-24 { padding: 24rpx; }
.p-32 { padding: 32rpx; }

/* Flex 布局 */
.flex {
  display: flex;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.items-center {
  align-items: center;
}

.justify-between {
  justify-content: space-between;
}

.justify-center {
  justify-content: center;
}

.flex-1 {
  flex: 1;
}

/* 图片 */
.image-full {
  width: 100%;
  height: 100%;
}

/* 步骤指示器 */
.step-indicator {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.step-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #eeeeee;
}

.step-dot.active {
  background: #d6a84f;
}

.step-line {
  flex: 1;
  height: 2rpx;
  background: #eeeeee;
  margin: 0 8rpx;
}

.step-text {
  font-size: 22rpx;
  color: #666666;
  margin-top: 8rpx;
}
