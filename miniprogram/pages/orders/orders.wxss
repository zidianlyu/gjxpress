/* 筛选栏 */
.filter-bar {
  white-space: nowrap;
  background: #fff;
  padding: 12px 16px;
  margin: -16px -16px 16px -16px;
  border-bottom: 1px solid #f0f0f0;
}

.filter-item {
  display: inline-block;
  padding: 6px 16px;
  margin-right: 8px;
  background: #f5f5f5;
  border-radius: 16px;
  font-size: 13px;
  color: #666;
}

.filter-item.active {
  background: #1890ff;
  color: #fff;
}

/* 订单列表 */
.order-list {
  margin-top: 8px;
}

.order-card {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
}

/* 订单头部 */
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding-bottom: 12px;
  border-bottom: 1px solid #f5f5f5;
}

.order-id-section {
  flex: 1;
  overflow: hidden;
}

.order-id {
  display: block;
  font-size: 14px;
  color: #333;
  font-weight: 500;
  margin-bottom: 4px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-time {
  font-size: 12px;
  color: #999;
}

/* 订单内容 */
.order-body {
  padding: 12px 0;
  border-bottom: 1px solid #f5f5f5;
}

.package-count {
  display: flex;
  align-items: center;
  font-size: 14px;
  color: #666;
  margin-bottom: 8px;
}

.package-icon {
  margin-right: 8px;
  font-size: 16px;
}

.order-weight {
  font-size: 13px;
  color: #999;
  margin-bottom: 4px;
}

.order-price {
  display: flex;
  align-items: baseline;
  margin-top: 8px;
}

.price-label {
  font-size: 13px;
  color: #666;
  margin-right: 4px;
}

.price-value {
  font-size: 18px;
  color: #ff4d4f;
  font-weight: 600;
}

/* 订单底部 */
.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 12px;
}

.payment-status {
  display: flex;
  align-items: center;
}

.status-label {
  font-size: 13px;
  color: #666;
  margin-right: 4px;
}

.status-value {
  font-size: 13px;
  font-weight: 500;
}

.status-success {
  color: #52c41a;
}

.status-danger {
  color: #ff4d4f;
}

.status-warning {
  color: #faad14;
}

.arrow {
  color: #ccc;
  font-size: 14px;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 64px 32px;
}

.empty-icon {
  font-size: 64px;
  margin-bottom: 16px;
  opacity: 0.5;
}

.empty-text {
  display: block;
  font-size: 16px;
  color: #666;
  margin-bottom: 8px;
}

.empty-subtext {
  display: block;
  font-size: 13px;
  color: #999;
  margin-bottom: 24px;
}

/* 加载中 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48px;
  color: #999;
  font-size: 13px;
}

.loading-spinner {
  width: 32px;
  height: 32px;
  border: 3px solid #f3f3f3;
  border-top: 3px solid #1890ff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 12px;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}
