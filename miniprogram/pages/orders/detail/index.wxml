<view class="page-container">
  <!-- 加载状态 -->
  <view class="loading" wx:if="{{loading}}">
    <view class="loading-text">加载中...</view>
  </view>

  <!-- 错误状态 -->
  <error-state 
    wx:elif="{{error}}" 
    message="{{error}}"
    bind:retry="onRetry"
  />

  <!-- 内容区域 -->
  <scroll-view wx:elif="{{order}}" class="detail-content" scroll-y>
    <!-- 订单状态卡片 -->
    <view class="card status-card">
      <view class="status-row">
        <view class="status-label">订单状态</view>
        <status-tag label="{{order.statusLabel}}" type="{{order.statusType}}"></status-tag>
      </view>
      <view class="status-row">
        <view class="status-label">支付状态</view>
        <status-tag label="{{order.paymentStatusLabel}}" type="{{order.paymentStatusType}}"></status-tag>
      </view>
      <view class="order-no-row">
        <text class="order-no-label">订单号</text>
        <text class="order-no-value">{{order.orderNo}}</text>
      </view>
    </view>

    <!-- 包裹列表 -->
    <view class="card packages-card" wx:if="{{order.packages && order.packages.length > 0}}">
      <view class="card-title">包裹列表 ({{order.packages.length}})</view>
      <view class="packages-list">
        <package-card 
          wx:for="{{order.packages}}" 
          wx:key="id"
          package="{{item}}"
          showActions="{{item.status === 'USER_CONFIRM_PENDING'}}"
          bind:confirm="onConfirmPackage"
          bind:issue="onReportIssue"
        ></package-card>
      </view>
    </view>

    <!-- 费用信息 -->
    <view class="card fee-card" wx:if="{{order.chargeableWeight || order.finalPrice}}">
      <view class="card-title">费用信息</view>
      <view class="fee-list">
        <view class="fee-row" wx:if="{{order.totalActualWeight}}">
          <text class="fee-label">实际重量</text>
          <text class="fee-value">{{order.totalActualWeight}} kg</text>
        </view>
        <view class="fee-row" wx:if="{{order.totalVolumeWeight}}">
          <text class="fee-label">体积重量</text>
          <text class="fee-value">{{order.totalVolumeWeight}} kg</text>
        </view>
        <view class="fee-row" wx:if="{{order.chargeableWeight}}">
          <text class="fee-label">计费重量</text>
          <text class="fee-value highlight">{{order.chargeableWeight}} kg</text>
        </view>
        <view class="divider" wx:if="{{order.finalPrice}}"></view>
        <view class="fee-row total-row" wx:if="{{order.finalPrice}}">
          <text class="fee-label">费用</text>
          <text class="fee-value price">{{order.currency === 'USD' ? '$' : '¥'}}{{order.finalPrice}}</text>
        </view>
      </view>
    </view>

    <!-- 物流信息 -->
    <view class="card shipment-card" wx:if="{{order.shipment}}">
      <view class="card-title">物流信息</view>
      <view class="shipment-list">
        <view class="shipment-row">
          <text class="shipment-label">物流渠道</text>
          <text class="shipment-value">{{order.shipment.provider}}</text>
        </view>
        <view class="shipment-row" wx:if="{{order.shipment.trackingNumber}}">
          <text class="shipment-label">运单号</text>
          <view class="tracking-number-wrap">
            <text class="shipment-value">{{order.shipment.trackingNumber}}</text>
            <text class="copy-link" bindtap="copyTrackingNumber" data-number="{{order.shipment.trackingNumber}}">复制</text>
          </view>
        </view>
        <view class="shipment-row" wx:if="{{order.shipment.status}}">
          <text class="shipment-label">物流状态</text>
          <text class="shipment-value">{{order.shipment.status}}</text>
        </view>
        <view class="shipment-row" wx:if="{{order.shipment.shippedAt}}">
          <text class="shipment-label">发货时间</text>
          <text class="shipment-value">{{order.shipment.shippedAt}}</text>
        </view>
        <view class="shipment-row" wx:if="{{order.shipment.estimatedArrivalAt}}">
          <text class="shipment-label">预计到达</text>
          <text class="shipment-value">{{order.shipment.estimatedArrivalAt}}</text>
        </view>
      </view>
    </view>

    <!-- 底部安全区域 -->
    <view class="safe-area-bottom"></view>
  </scroll-view>
</view>

<!-- 异常提交弹窗 -->
<view class="modal-mask" wx:if="{{showIssueModal}}" bindtap="closeIssueModal">
  <view class="modal-content" catchtap="preventClose">
    <view class="modal-header">
      <text class="modal-title">提交问题</text>
      <text class="modal-close" bindtap="closeIssueModal">✕</text>
    </view>
    <view class="modal-body">
      <textarea 
        class="issue-textarea" 
        placeholder="请描述您发现的问题..."
        value="{{issueDescription}}"
        bindinput="onIssueInput"
        maxlength="500"
      />
      <view class="textarea-count">{{issueDescription.length}}/500</view>
    </view>
    <view class="modal-footer">
      <view class="btn btn-default" bindtap="closeIssueModal">取消</view>
      <view class="btn btn-primary {{submitting ? 'disabled' : ''}}" bindtap="submitIssue">
        {{submitting ? '提交中...' : '提交'}}
      </view>
    </view>
  </view>
</view>
