.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 96rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #999999;
}

.detail-content {
  height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.status-card {
  padding: 28rpx;
}

.status-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.status-label {
  font-size: 28rpx;
  color: #666666;
}

.order-no-row {
  display: flex;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f5f5f5;
}

.order-no-label {
  font-size: 26rpx;
  color: #999999;
  margin-right: 16rpx;
}

.order-no-value {
  font-size: 26rpx;
  color: #666666;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f1f1f;
  margin-bottom: 24rpx;
}

.fee-card, .shipment-card, .packages-card {
  padding: 28rpx;
}

.fee-list, .shipment-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.fee-row, .shipment-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.fee-label, .shipment-label {
  font-size: 28rpx;
  color: #666666;
}

.fee-value, .shipment-value {
  font-size: 28rpx;
  color: #1f1f1f;
  font-weight: 500;
}

.fee-value.highlight {
  color: #d6a84f;
}

.fee-value.price {
  color: #d6a84f;
  font-size: 36rpx;
  font-weight: 700;
}

.total-row {
  padding-top: 20rpx;
  border-top: 1rpx solid #f5f5f5;
}

.tracking-number-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.copy-link {
  font-size: 24rpx;
  color: #d6a84f;
  padding: 4rpx 12rpx;
  background: #fff7e6;
  border-radius: 8rpx;
}

.divider {
  height: 1rpx;
  background: #f5f5f5;
  margin: 8rpx 0;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: #fff;
  border-radius: 24rpx;
  width: 80%;
  max-width: 600rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f1f1f;
}

.modal-close {
  font-size: 32rpx;
  color: #999999;
  padding: 8rpx;
}

.modal-body {
  padding: 32rpx;
}

.issue-textarea {
  width: 100%;
  height: 240rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

.textarea-count {
  text-align: right;
  font-size: 24rpx;
  color: #999999;
  margin-top: 16rpx;
}

.modal-footer {
  display: flex;
  padding: 24rpx 32rpx 32rpx;
  gap: 24rpx;
}

.modal-footer .btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  text-align: center;
}

.modal-footer .btn-primary {
  background: #d6a84f;
  color: #fff;
}

.modal-footer .btn-primary.disabled {
  opacity: 0.6;
}

.modal-footer .btn-default {
  background: #f5f5f5;
  color: #666666;
}
