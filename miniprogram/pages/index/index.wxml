<view class="container">
  <!-- 品牌展示 -->
  <view class="brand-section">
    <view class="brand-logo">GJX</view>
    <view class="brand-name">广骏供应链服务</view>
    <view class="brand-slogan">看得见的跨境物流</view>
  </view>

  <!-- 快捷入口 -->
  <view class="card">
    <view class="card-title">快捷入口</view>
    <view class="grid-menu">
      <view class="grid-item" bindtap="goToAddress">
        <view class="grid-icon" style="background: #e6f7ff; color: #1890ff;">
          <text class="iconfont">[仓]</text>
        </view>
        <text class="grid-text">仓库地址</text>
      </view>
      <view class="grid-item" bindtap="goToOrders">
        <view class="grid-icon" style="background: #f6ffed; color: #52c41a;">
          <text class="iconfont">[单]</text>
        </view>
        <text class="grid-text">我的订单</text>
      </view>
      <view class="grid-item" bindtap="contactService">
        <view class="grid-icon" style="background: #fff7e6; color: #faad14;">
          <text class="iconfont">[服]</text>
        </view>
        <text class="grid-text">联系客服</text>
      </view>
      <view class="grid-item" bindtap="copyAddress">
        <view class="grid-icon" style="background: #fff1f0; color: #ff4d4f;">
          <text class="iconfont">[址]</text>
        </view>
        <text class="grid-text">复制地址</text>
      </view>
    </view>
  </view>

  <!-- 使用指南 -->
  <view class="card">
    <view class="card-title">使用指南</view>
    <view class="guide-steps">
      <view class="step-item">
        <view class="step-num">1</view>
        <view class="step-content">
          <text class="step-title">复制仓库地址</text>
          <text class="step-desc">在淘宝/京东等平台填写收货地址</text>
        </view>
      </view>
      <view class="step-item">
        <view class="step-num">2</view>
        <view class="step-content">
          <text class="step-title">等待包裹入库</text>
          <text class="step-desc">仓库收到包裹后会拍照入库</text>
        </view>
      </view>
      <view class="step-item">
        <view class="step-num">3</view>
        <view class="step-content">
          <text class="step-title">确认包裹信息</text>
          <text class="step-desc">查看照片，确认无误后提交</text>
        </view>
      </view>
      <view class="step-item">
        <view class="step-num">4</view>
        <view class="step-content">
          <text class="step-title">支付并等待发货</text>
          <text class="step-desc">支付运费后安排国际发货</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 最近订单 -->
  <view class="card" wx:if="{{recentOrders.length > 0}}">
    <view class="card-title">
      <text>最近订单</text>
      <text class="more-link" bindtap="goToOrders">查看全部 ></text>
    </view>
    <view class="order-list">
      <view class="order-item" wx:for="{{recentOrders}}" wx:key="id" bindtap="goToOrderDetail" data-id="{{item.id}}">
        <view class="order-header">
          <text class="order-id">订单号: {{item.id}}</text>
          <view class="tag tag-{{api.utils.getStatusDisplay(item.status).type}}">
            {{api.utils.getStatusDisplay(item.status).label}}
          </view>
        </view>
        <view class="order-info">
          <text>包裹: {{item.packages && item.packages.length ? item.packages.length : 0}} 个</text>
          <text class="order-time">{{item.created_at}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 登录提示 -->
  <view class="card login-card" wx:if="{{!isLogin}}">
    <text class="login-tip">登录后查看您的订单和包裹</text>
    <button class="btn btn-primary" bindtap="goToLogin">立即登录</button>
  </view>
</view>
