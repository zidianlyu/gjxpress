/* 品牌展示 */
.brand-section {
  text-align: center;
  padding: 32px 16px;
  background: linear-gradient(135deg, #1890ff 0%, #36cfc9 100%);
  margin: -16px -16px 16px -16px;
}

.brand-logo {
  width: 80px;
  height: 80px;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20px;
  margin: 0 auto 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32px;
  font-weight: bold;
  backdrop-filter: blur(10px);
}

.brand-name {
  color: #fff;
  font-size: 24px;
  font-weight: 600;
  margin-bottom: 8px;
}

.brand-slogan {
  color: rgba(255, 255, 255, 0.8);
  font-size: 14px;
}

/* 快捷入口 */
.grid-item .iconfont {
  font-size: 24px;
}

/* 使用指南 */
.guide-steps {
  padding: 8px 0;
}

.step-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16px;
}

.step-item:last-child {
  margin-bottom: 0;
}

.step-num {
  width: 28px;
  height: 28px;
  background: #1890ff;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: 600;
  margin-right: 12px;
  flex-shrink: 0;
}

.step-content {
  flex: 1;
}

.step-title {
  display: block;
  font-size: 15px;
  font-weight: 500;
  color: #333;
  margin-bottom: 4px;
}

.step-desc {
  display: block;
  font-size: 13px;
  color: #999;
}

/* 订单列表 */
.more-link {
  float: right;
  color: #1890ff;
  font-size: 13px;
  font-weight: normal;
}

.order-list {
  margin-top: 8px;
}

.order-item {
  padding: 12px 0;
  border-bottom: 1px solid #f0f0f0;
}

.order-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.order-id {
  font-size: 14px;
  color: #666;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 8px;
}

.order-info {
  display: flex;
  justify-content: space-between;
  font-size: 13px;
  color: #999;
}

.order-time {
  color: #bbb;
}

/* 登录卡片 */
.login-card {
  text-align: center;
  padding: 32px 24px;
}

.login-tip {
  display: block;
  color: #666;
  margin-bottom: 16px;
  font-size: 14px;
}
