<view class="page-container">
  <!-- 用户信息区域 -->
  <view class="user-section">
    <view class="brand-info">
      <view class="brand-logo">🚚</view>
      <view class="brand-name">广骏供应链服务</view>
    </view>
    <view class="user-info" wx:if="{{user}}">
      <view class="user-label">用户ID</view>
      <view class="user-code">{{user.userCode}}</view>
    </view>
  </view>

  <!-- 菜单列表 -->
  <view class="menu-list">
    <view class="menu-item" bindtap="goToOrders">
      <view class="menu-icon" style="background: #e6f7ff; color: #1890ff;">📦</view>
      <view class="menu-content">
        <view class="menu-title">我的订单</view>
        <view class="menu-arrow">›</view>
      </view>
    </view>
    
    <view class="menu-item" bindtap="goToAddress">
      <view class="menu-icon" style="background: #f6ffed; color: #18a058;">📍</view>
      <view class="menu-content">
        <view class="menu-title">地址管理</view>
        <view class="menu-arrow">›</view>
      </view>
    </view>
    
    <view class="menu-item" bindtap="goToCustomerService">
      <view class="menu-icon" style="background: #fff7e6; color: #d6a84f;">💬</view>
      <view class="menu-content">
        <view class="menu-title">客服中心</view>
        <view class="menu-arrow">›</view>
      </view>
    </view>
    
    <view class="menu-item" bindtap="goToPrivacy">
      <view class="menu-icon" style="background: #f0f5ff; color: #2f54eb;">🔒</view>
      <view class="menu-content">
        <view class="menu-title">隐私政策</view>
        <view class="menu-arrow">›</view>
      </view>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section" wx:if="{{user}}">
    <view class="logout-btn" bindtap="onLogout">退出登录</view>
  </view>

  <!-- 版本信息 -->
  <view class="version-section">
    <view class="version-text">当前版本 {{version}}</view>
  </view>
</view>
