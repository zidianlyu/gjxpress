.user-section {
  background: linear-gradient(135deg, #d6a84f 0%, #c49a47 100%);
  padding: 64rpx 32rpx;
  color: #fff;
  text-align: center;
}

.brand-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.brand-logo {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  margin-bottom: 24rpx;
}

.brand-name {
  font-size: 36rpx;
  font-weight: 600;
}

.user-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.user-label {
  font-size: 26rpx;
  opacity: 0.9;
}

.user-code {
  font-size: 56rpx;
  font-weight: 700;
}

.menu-list {
  background: #fff;
  margin: 24rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
}

.menu-item:not(:last-child) .menu-content {
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.menu-content {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.menu-title {
  font-size: 30rpx;
  color: #1f1f1f;
}

.menu-arrow {
  font-size: 36rpx;
  color: #cccccc;
}

.logout-section {
  padding: 32rpx;
}

.logout-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx;
  background: #fff;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #d03050;
}

.version-section {
  padding: 48rpx 32rpx;
  text-align: center;
}

.version-text {
  font-size: 24rpx;
  color: #999999;
}
