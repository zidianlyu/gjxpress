.header-section {
  background: linear-gradient(135deg, #d6a84f 0%, #c49a47 100%);
  padding: 64rpx 32rpx;
  text-align: center;
  color: #fff;
}

.header-icon {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  margin: 0 auto 24rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.header-subtitle {
  font-size: 28rpx;
  opacity: 0.9;
}

.contact-section {
  padding: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f1f1f;
  margin-bottom: 24rpx;
}

.contact-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 28rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.contact-info {
  flex: 1;
}

.contact-label {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.contact-value {
  font-size: 30rpx;
  color: #1f1f1f;
  font-weight: 500;
}

.contact-action {
  padding: 8rpx 20rpx;
  background: #d6a84f;
  color: #fff;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.faq-section {
  padding: 0 32rpx 32rpx;
}

.faq-list {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
}

.faq-item {
  border-bottom: 1rpx solid #f5f5f5;
}

.faq-item:last-child {
  border-bottom: none;
}

.faq-item.expanded {
  background: #fafafa;
}

.faq-question {
  display: flex;
  align-items: center;
  padding: 28rpx;
  gap: 16rpx;
}

.faq-q {
  font-size: 28rpx;
  color: #d6a84f;
  font-weight: 600;
  flex-shrink: 0;
}

.faq-text {
  flex: 1;
  font-size: 28rpx;
  color: #1f1f1f;
  line-height: 1.5;
}

.faq-arrow {
  font-size: 24rpx;
  color: #cccccc;
  transition: transform 0.3s;
}

.faq-item.expanded .faq-arrow {
  transform: rotate(180deg);
}

.faq-answer {
  display: flex;
  gap: 16rpx;
  padding: 0 28rpx 28rpx;
}

.faq-a {
  font-size: 28rpx;
  color: #18a058;
  font-weight: 600;
  flex-shrink: 0;
}

.faq-answer-text {
  flex: 1;
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}

.footer-section {
  padding: 32rpx;
  text-align: center;
}

.footer-text {
  font-size: 26rpx;
  color: #999999;
}
