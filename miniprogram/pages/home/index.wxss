/* 品牌区域 - 补充样式 */
.brand-row {
  display: flex;
  align-items: center;
}

.brand-logo {
  width: 96rpx;
  height: 96rpx;
  border-radius: 20rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
  background: #fff;
}

.brand-text {
  flex: 1;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 96rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #999999;
}

.user-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.user-info {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.user-label {
  font-size: 28rpx;
  color: #666666;
}

.user-code {
  font-size: 40rpx;
  font-weight: 700;
  color: #d6a84f;
}

.user-tip {
  font-size: 24rpx;
  color: #999999;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f1f1f;
  margin-bottom: 24rpx;
}

.quick-menu {
  display: flex;
  justify-content: space-around;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 32rpx;
}

.quick-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.quick-text {
  font-size: 26rpx;
  color: #666666;
}

.stat-grid {
  display: flex;
  justify-content: space-around;
  padding: 16rpx 0;
}

.stat-item {
  text-align: center;
  padding: 16rpx 24rpx;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 26rpx;
  color: #666666;
}

.guide-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.guide-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.guide-step {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #d6a84f;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.guide-content {
  flex: 1;
}

.guide-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #1f1f1f;
  margin-bottom: 4rpx;
}

.guide-desc {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.5;
}

.service-desc {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.8;
}
