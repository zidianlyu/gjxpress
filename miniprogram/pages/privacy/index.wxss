.header-section {
  background: linear-gradient(135deg, #d6a84f 0%, #c49a47 100%);
  padding: 64rpx 32rpx;
  text-align: center;
  color: #fff;
}

.header-title {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.header-subtitle {
  font-size: 28rpx;
  opacity: 0.9;
}

.content-section {
  padding: 32rpx;
}

.intro-text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
  margin-bottom: 48rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
}

.privacy-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f1f1f;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.section-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.list-item {
  display: flex;
  gap: 16rpx;
}

.item-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #d6a84f;
  margin-top: 10rpx;
  flex-shrink: 0;
}

.item-text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
  flex: 1;
}

.update-section, .contact-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.update-title, .contact-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f1f1f;
  margin-bottom: 20rpx;
}

.update-text, .contact-text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
}

.footer-text {
  text-align: center;
  font-size: 24rpx;
  color: #999999;
  margin-top: 48rpx;
  padding-bottom: 48rpx;
}
