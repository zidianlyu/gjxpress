/* 提示卡片 */
.tip-card {
  background: #e6f7ff;
  border: 1px solid #91d5ff;
  border-radius: 8px;
  padding: 12px 16px;
  margin-bottom: 16px;
  display: flex;
  align-items: flex-start;
}

.tip-icon {
  font-size: 18px;
  margin-right: 8px;
  flex-shrink: 0;
}

.tip-text {
  flex: 1;
  font-size: 13px;
  color: #1890ff;
  line-height: 1.6;
}

/* 用户代码 */
.user-code-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px;
  background: #f6ffed;
  border: 2px dashed #b7eb8f;
  border-radius: 8px;
  margin-bottom: 8px;
}

.user-code {
  font-size: 32px;
  font-weight: bold;
  color: #52c41a;
  letter-spacing: 4px;
}

.btn-copy-small {
  padding: 6px 16px;
  background: #52c41a;
  color: #fff;
  border: none;
  border-radius: 4px;
  font-size: 13px;
}

.code-tip {
  display: block;
  font-size: 12px;
  color: #888;
  margin-top: 8px;
}

/* 地址卡片 */
.address-card {
  background: #fafafa;
  border-radius: 8px;
  padding: 16px;
  margin-bottom: 16px;
}

.address-row {
  display: flex;
  padding: 8px 0;
  border-bottom: 1px solid #f0f0f0;
}

.address-row:last-child {
  border-bottom: none;
}

.address-label {
  width: 70px;
  color: #666;
  font-size: 14px;
  flex-shrink: 0;
}

.address-value {
  flex: 1;
  color: #333;
  font-size: 14px;
  word-break: break-all;
}

.btn-block {
  width: 100%;
  margin-top: 8px;
}

.btn-icon {
  margin-right: 4px;
}

/* 填写示例 */
.example-box {
  background: #f5f5f5;
  border-radius: 8px;
  padding: 16px;
}

.example-line {
  display: flex;
  padding: 8px 0;
  border-bottom: 1px dashed #ddd;
}

.example-line:last-child {
  border-bottom: none;
}

.example-label {
  width: 80px;
  color: #666;
  font-size: 13px;
  flex-shrink: 0;
}

.example-value {
  flex: 1;
  color: #333;
  font-size: 13px;
  font-weight: 500;
}

/* 温馨提示 */
.notice-card {
  background: #fff7e6;
  border: 1px solid #ffd591;
}

.notice-list {
  padding: 8px 0;
}

.notice-item {
  display: block;
  font-size: 13px;
  color: #666;
  line-height: 1.8;
  padding: 4px 0;
}
