<view class="page-container">
  <!-- 加载状态 -->
  <view class="loading" wx:if="{{loading}}">
    <view class="loading-text">加载中...</view>
  </view>

  <!-- 错误状态 -->
  <error-state 
    wx:elif="{{error}}" 
    message="{{error}}"
    bind:retry="onRetry"
  />

  <!-- 内容区域 -->
  <block wx:elif="{{address}}">
    <!-- 用户ID提示 -->
    <view class="user-code-section">
      <view class="user-code-label">您的专属用户ID</view>
      <view class="user-code-value">{{address.userCode}}</view>
      <view class="user-code-tip">下单时请务必保留此ID</view>
    </view>

    <!-- 地址卡片 -->
    <view class="address-card-section">
      <view class="address-card">
        <view class="address-row">
          <view class="address-label">收件人</view>
          <view class="address-value">{{address.receiverName}}</view>
        </view>
        <view class="address-row">
          <view class="address-label">电话</view>
          <view class="address-value">{{address.phone}}</view>
        </view>
        <view class="address-row">
          <view class="address-label">地址</view>
          <view class="address-value">{{address.province}}{{address.city}}{{address.district}}{{address.addressLine}}</view>
        </view>
        <view class="address-row">
          <view class="address-label">邮编</view>
          <view class="address-value">{{address.postalCode}}</view>
        </view>
      </view>

      <!-- 复制按钮 -->
      <view class="copy-btn-main {{copied ? 'copied' : ''}}" bindtap="copyAddress">
        <text wx:if="{{!copied}}">一键复制完整地址</text>
        <text wx:else>已复制</text>
      </view>
    </view>

    <!-- 使用说明 -->
    <view class="guide-section">
      <view class="guide-title">如何使用</view>
      <view class="guide-content">
        <view class="guide-step-item">
          <view class="step-num">1</view>
          <view class="step-text">点击上方按钮复制完整地址</view>
        </view>
        <view class="guide-step-item">
          <view class="step-num">2</view>
          <view class="step-text">打开淘宝、京东等电商平台</view>
        </view>
        <view class="guide-step-item">
          <view class="step-num">3</view>
          <view class="step-text">在收货地址中粘贴并保存</view>
        </view>
        <view class="guide-step-item">
          <view class="step-num">4</view>
          <view class="step-text">下单时选择此地址</view>
        </view>
      </view>
    </view>

    <!-- 注意事项 -->
    <view class="notice-section">
      <view class="notice-title">注意事项</view>
      <view class="notice-list">
        <view class="notice-item">• 请务必保留收件人中的用户ID，这是识别您包裹的关键信息</view>
        <view class="notice-item">• 如订单中有多个包裹，可同时发往同一地址</view>
        <view class="notice-item">• 包裹到达仓库后会拍照并通知您确认</view>
        <view class="notice-item">• 如有疑问请联系客服</view>
      </view>
    </view>
  </block>
</view>
