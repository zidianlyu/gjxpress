.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 96rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #999999;
}

.user-code-section {
  background: linear-gradient(135deg, #d6a84f 0%, #c49a47 100%);
  padding: 48rpx 32rpx;
  text-align: center;
  color: #fff;
}

.user-code-label {
  font-size: 28rpx;
  opacity: 0.9;
  margin-bottom: 16rpx;
}

.user-code-value {
  font-size: 64rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.user-code-tip {
  font-size: 26rpx;
  opacity: 0.8;
}

.address-card-section {
  padding: 32rpx;
}

.address-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.address-row {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.address-row:last-child {
  border-bottom: none;
}

.address-label {
  width: 120rpx;
  font-size: 28rpx;
  color: #999999;
  flex-shrink: 0;
}

.address-value {
  flex: 1;
  font-size: 28rpx;
  color: #1f1f1f;
  font-weight: 500;
  line-height: 1.5;
}

.copy-btn-main {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  background: #d6a84f;
  color: #fff;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.copy-btn-main.copied {
  background: #18a058;
}

.copy-btn-main:active {
  background: #c49a47;
}

.guide-section {
  background: #fff;
  margin: 0 32rpx 32rpx;
  border-radius: 20rpx;
  padding: 32rpx;
}

.guide-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f1f1f;
  margin-bottom: 32rpx;
}

.guide-content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.guide-step-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.step-num {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #f5f5f5;
  color: #666666;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.step-text {
  font-size: 28rpx;
  color: #666666;
}

.notice-section {
  background: #fff;
  margin: 0 32rpx 48rpx;
  border-radius: 20rpx;
  padding: 32rpx;
}

.notice-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f1f1f;
  margin-bottom: 24rpx;
}

.notice-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.notice-item {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
}
