.image-gallery {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.gallery-item {
  width: 200rpx;
  position: relative;
}

.gallery-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
}

.image-type {
  position: absolute;
  bottom: 8rpx;
  left: 8rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
