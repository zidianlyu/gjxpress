<view class="package-card">
  <view class="package-header">
    <view class="package-no">{{package.packageNo || package.id}}</view>
    <status-tag label="{{statusLabel}}" type="{{statusType}}"></status-tag>
  </view>
  
  <view class="package-info">
    <view class="info-row" wx:if="{{package.domesticTrackingNo}}">
      <text class="info-label">国内单号</text>
      <text class="info-value">{{package.domesticTrackingNo}}</text>
    </view>
    <view class="info-row" wx:if="{{package.sourcePlatform}}">
      <text class="info-label">来源平台</text>
      <text class="info-value">{{package.sourcePlatform}}</text>
    </view>
    <view class="info-row" wx:if="{{package.actualWeight}}">
      <text class="info-label">实际重量</text>
      <text class="info-value">{{package.actualWeight}} kg</text>
    </view>
    <view class="info-row" wx:if="{{package.lengthCm}}">
      <text class="info-label">尺寸</text>
      <text class="info-value">{{package.lengthCm}} × {{package.widthCm}} × {{package.heightCm}} cm</text>
    </view>
    <view class="info-row" wx:if="{{package.volumeWeight}}">
      <text class="info-label">体积重量</text>
      <text class="info-value">{{package.volumeWeight}} kg</text>
    </view>
    <view class="info-row" wx:if="{{package.inboundAt}}">
      <text class="info-label">入库时间</text>
      <text class="info-value">{{package.inboundAt}}</text>
    </view>
  </view>

  <view class="package-images" wx:if="{{package.images && package.images.length > 0}}">
    <view class="images-title">入库照片</view>
    <view class="images-list">
      <view 
        class="image-item" 
        wx:for="{{package.images}}" 
        wx:key="id"
        bindtap="onImageTap"
        data-url="{{item.url}}"
      >
        <image 
          src="{{item.url}}" 
          mode="aspectFill" 
          class="image-thumbnail"
          lazy-load
        />
        <view class="image-type">{{item.imageType === 'OUTER' ? '外包装' : item.imageType === 'LABEL' ? '面单' : item.imageType === 'INNER' ? '内部' : '照片'}}</view>
      </view>
    </view>
  </view>

  <view class="package-actions" wx:if="{{showActions && package.status === 'USER_CONFIRM_PENDING'}}">
    <view class="action-btn btn-success" bindtap="onConfirmTap">确认无误</view>
    <view class="action-btn btn-warning" bindtap="onIssueTap">有问题</view>
  </view>
</view>
